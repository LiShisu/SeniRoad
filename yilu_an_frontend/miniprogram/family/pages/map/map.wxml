<!--family/pages/map/map.wxml-->
<view class="container">
  <view class="map-container">
    <image src="../../images/map_placeholder.png" class="map-image"></image>
    <view class="location-marker">
      <text class="marker-text">老人位置</text>
    </view>
  </view>
  
  <view class="info-panel">
    <view class="info-item">
      <text class="info-label">当前位置</text>
      <text class="info-value">北京市朝阳区建国路88号</text>
    </view>
    <view class="info-item">
      <text class="info-label">最后更新</text>
      <text class="info-value">2024-01-01 12:00:00</text>
    </view>
    <view class="info-item">
      <text class="info-label">状态</text>
      <text class="info-value status-normal">正常</text>
    </view>
  </view>
  
  <view class="control-buttons">
    <view class="control-btn" bindtap="refreshLocation">
      <text class="btn-text">刷新位置</text>
    </view>
    <view class="control-btn" bindtap="callElder">
      <text class="btn-text">联系老人</text>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <guard-bottom-nav activeItem="location" />

</view>