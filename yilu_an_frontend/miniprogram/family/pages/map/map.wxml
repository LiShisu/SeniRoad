<view class="container">
  <!-- 自定义顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <td-icon name="chevron-left" size="48rpx" color="#333333" />
    </view>
    <view class="nav-title">实时位置</view>
    <view class="nav-right"></view>
  </view>

  <!-- 地图容器 -->
  <view class="map-container">
    <map
      id="map"
      class="map"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="16"
      show-location="{{false}}"
      markers="{{markers}}"
    ></map>
  </view>

  <!-- 底部浮层 -->
  <view class="bottom-panel">
    <view class="location-info">
      <text class="location-title">{{locationTitle}}</text>
      <text class="location-detail">{{locationDetail}}</text>
      <text class="update-time">{{updateTime}}</text>
    </view>
    <view class="action-buttons">
      <button class="action-btn" bindtap="makeCall">
        <td-icon name="call" size="36rpx" />
        <text style="font-size: 28rpx;">打电话</text>
      </button>
      <button class="action-btn" bindtap="sendMessage">
        <td-icon name="chat" size="36rpx" />
        <text style="font-size: 28rpx;">发消息</text>
      </button>
    </view>
  </view>
</view>
