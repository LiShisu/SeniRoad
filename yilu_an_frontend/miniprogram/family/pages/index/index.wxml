<view class="container">
  <!-- 头部信息区 -->
  <view class="header-section">
    <view class="avatar">
      <avatar nickname="{{elderName}}" background-color="#FFFFFF" text-color="#4B8AFF" />
    </view>
    <view class="info">
      <text class="name">{{elderName}}</text>
      <text class="subtitle-text">实时守护家人出行安全</text>
    </view>
    <view class="switch-icon" bindtap="switchElder">
      <image src="/assets/svg/refresh-icon.svg" class="switch-img"></image>
    </view>
  </view>

  <!-- 状态卡片 -->
  <view class="status-card">
    <view class="status-header">
      <view class="online-status">
        <view class="dot online"></view>
        <text class="online-text">在线状态</text>
      </view>
      <view class="safe-tag">安全</view>
    </view>
    <view class="info-row">
      <text class="info-label">📍 当前位置：</text>
      <text class="info-value">{{currentLocation}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">⏱️ 最后更新：</text>
      <text class="info-value">{{lastUpdate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">🚶 出行状态：</text>
      <text class="info-value">{{navigationStatus}}</text>
    </view>
    <view class="info-row last" wx:if="{{navigationStatus === '出行中' && destName}}">
      <text class="info-label">🎯 目的地：</text>
      <text class="info-value">{{destName}}</text>
    </view>
  </view>

  <!-- 快捷入口卡片 -->
  <view class="quick-entry-section">
    <view class="entry-card" bindtap="goToPlaces">
      <image src="/assets/svg/compass-icon.svg" class="entry-icon"></image>
      <text>预设常用地点</text>
      <view class="arrow">›</view>
    </view>
    <view class="entry-card" bindtap="goToRecords">
      <image src="/assets/svg/navigation-icon.svg" class="entry-icon"></image>
      <text>出行记录查询</text>
      <view class="arrow">›</view>
    </view>
    <view class="entry-card" bindtap="goToElders">
      <image src="/assets/svg/user-icon.svg" class="entry-icon"></image>
      <text>老人管理</text>
      <view class="arrow">›</view>
    </view>
  </view>

  <!-- 底部安全区 -->
  <view class="bottom-safe-area"></view>
</view>

<!-- 底部导航栏 -->
<guard-bottom-nav activeItem="home" />
