<view class="container">
  <!-- 自定义顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <td-icon name="chevron-left" size="48rpx" color="#333333" />
    </view>
    <view class="nav-title">出行记录查询</view>
    <view class="nav-right"></view>
  </view>

  <!-- 标签切换 -->
  <td-tabs value="{{currentTab}}" bind:change="onTabChange">
    <td-tab-panel value="all" label="全部" />
    <td-tab-panel value="today" label="今日" />
    <td-tab-panel value="week" label="本周" />
    <td-tab-panel value="month" label="本月" />
  </td-tabs>

  <!-- 统计卡片 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-value">{{stats.trips}}</text>
      <text class="stat-label">出行次数</text>
    </view>
  </view>

  <!-- 历史记录列表 -->
  <view class="records-list">
    <view class="record-item" wx:for="{{records}}" wx:key="id">
      <view class="record-note">
        <view class="record-header">
          <text class="record-time">{{item.time}}</text>
          <td-tag wx:if="{{item.status === 1}}" theme="success" variant="light" size="small">进行中</td-tag>
          <td-tag wx:elif="{{item.status === 2}}" theme="primary" variant="light" size="small">已完成</td-tag>
          <td-tag wx:elif="{{item.status === 3}}" theme="danger" variant="light" size="small">已取消</td-tag>
        </view>
        <text class="record-path">{{item.path}}</text>
        <view class="record-link" bindtap="viewDetail" data-id="{{item.id}}">
          <text>查看轨迹详情</text>
          <td-icon name="chevron-right" size="28rpx" color="#4B8AFF" />
        </view>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>