<!-- elder/pages/login/login.wxml -->
<view class="container">
  <view class="login-form">
    <view class="logo">
      <text class="app-name">颐路安</text>
      <text class="app-slogan">您的智能出行助手</text>
    </view>
    
    <view class="form-group">
      <view class="input-wrapper">
        <text class="input-label">手机号</text>
        <input 
          class="input" 
          type="number" 
          placeholder="请输入手机号" 
          bindinput="onPhoneChange"
          value="{{phone}}"
        />
      </view>
    </view>
    
    <view class="form-group">
      <view class="input-wrapper">
        <text class="input-label">密码</text>
        <view class="password-input">
          <input 
            class="input" 
            type="{{showPassword ? 'text' : 'password'}}" 
            placeholder="请输入密码" 
            bindinput="onPasswordChange"
            value="{{password}}"
          />
          <text class="toggle-password" bindtap="togglePassword">
            {{showPassword ? '隐藏' : '显示'}}
          </text>
        </view>
      </view>
    </view>
    
    <button 
      class="login-button" 
      bindtap="login"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      登录
    </button>
    
    <button 
      class="wechat-login-button" 
      bindtap="wechatLogin"
      loading="{{wechatLoading}}"
      disabled="{{wechatLoading}}"
    >
      <text class="wechat-icon">🟢</text>
      微信快捷登录
    </button>
    
    <view class="register-link">
      <text>还没有账号？</text>
      <navigator url="/elder/pages/register/register" class="link">立即注册</navigator>
    </view>
  </view>
</view>
