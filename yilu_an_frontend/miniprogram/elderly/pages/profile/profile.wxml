<!-- index.wxml -->
<view class="container">
  <!-- 顶部导航栏 -->
  <!-- <view class="nav-bar">
    <text class="nav-title">个人中心</text>
  </view> -->

  <!-- 个人信息区域 -->
  <view class="profile-section">
    <view class="avatar-container">
      <view class="avatar-wrapper" bindtap="chooseAvatar">
      <block wx:if="{{userInfo.avatar_url}}">
        <image class="avatar" src="{{userInfo.avatar_url}}" mode="aspectFill"></image>
      </block>
      <block wx:else>
        <view class="avatar-placeholder">
          <text class="avatar-placeholder-text">{{userInfo.nickname ? userInfo.nickname[0] : '无'}}</text>
        </view>
      </block>
    </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname}}</text>
        <text class="user-id">ID: {{userInfo.id}}</text>
      </view>
    </view>
  </view>

  <!-- 按钮容器 -->
  <view class="buttons-container">
    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item" bindtap="handleMenuClick" data-id="1">
        <view class="menu-left">
          <text class="menu-text">设置</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <view class="logout-btn" bindtap="logout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <elder-bottom-nav activeItem="profile" />

</view>