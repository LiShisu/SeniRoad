<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <text class="nav-title">常用地点</text>
  </view>

  <!-- 常用地点列表 -->
  <view class="section">
    <text class="section-title">我的常用地点</text>
    <view class="place-list">
      <view class="place-item" bindtap="selectPlace">
        <view class="place-icon home">
          <text class="icon-text">家</text>
        </view>
        <view class="place-info">
          <text class="place-name">家</text>
          <text class="place-address">北京市朝阳区建国路88号</text>
        </view>
        <view class="place-actions">
          <view class="action-btn navigate" bindtap="navigateToPlace">
            <text class="action-text">导航</text>
          </view>
          <view class="action-btn edit" bindtap="editPlace">
            <text class="action-text">编辑</text>
          </view>
        </view>
      </view>
      
      <view class="place-item" bindtap="selectPlace">
        <view class="place-icon hospital">
          <text class="icon-text">医院</text>
        </view>
        <view class="place-info">
          <text class="place-name">北京协和医院</text>
          <text class="place-address">北京市东城区帅府园1号</text>
        </view>
        <view class="place-actions">
          <view class="action-btn navigate" bindtap="navigateToPlace">
            <text class="action-text">导航</text>
          </view>
          <view class="action-btn edit" bindtap="editPlace">
            <text class="action-text">编辑</text>
          </view>
        </view>
      </view>
      
      <view class="place-item" bindtap="selectPlace">
        <view class="place-icon market">
          <text class="icon-text">菜市场</text>
        </view>
        <view class="place-info">
          <text class="place-name">三里屯菜市场</text>
          <text class="place-address">北京市朝阳区三里屯路19号</text>
        </view>
        <view class="place-actions">
          <view class="action-btn navigate" bindtap="navigateToPlace">
            <text class="action-text">导航</text>
          </view>
          <view class="action-btn edit" bindtap="editPlace">
            <text class="action-text">编辑</text>
          </view>
        </view>
      </view>
      
      <view class="place-item" bindtap="selectPlace">
        <view class="place-icon park">
          <text class="icon-text">公园</text>
        </view>
        <view class="place-info">
          <text class="place-name">朝阳公园</text>
          <text class="place-address">北京市朝阳区朝阳公园南路1号</text>
        </view>
        <view class="place-actions">
          <view class="action-btn navigate" bindtap="navigateToPlace">
            <text class="action-text">导航</text>
          </view>
          <view class="action-btn edit" bindtap="editPlace">
            <text class="action-text">编辑</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加新地点 -->
  <view class="add-section">
    <view class="add-btn" bindtap="addNewPlace">
      <text class="add-text">+ 添加新地点</text>
    </view>
  </view>

  <!-- 底部导航栏 -->
  <elder-bottom-nav />

</view>