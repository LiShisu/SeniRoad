<!--elderly/pages/navigate/navigate.wxml-->
<view class="container">
  <!-- 摄像头实景显示 -->
  <view class="camera-view">
    <!-- 摄像头预览区域 -->
    <live-pusher 
      class="live-pusher" 
      mode="SD" 
      autopush="true" 
      device-position="back" 
      style="width: 100%; height: 100%;"
    ></live-pusher>
  </view>
  
  <!-- 导航状态显示 -->
  <view class="nav-status" wx:if="{{navStatus === 'navigating'}}">
    导航中
  </view>
  <view class="nav-status paused" wx:else>
    暂停导航
  </view>
  
  <!-- 导航指示 -->
  <view class="nav-direction">
    <view class="direction-arrow">
      <view class="arrow-icon">↑</view>
    </view>
    <view class="direction-text">{{navInstruction}}</view>
  </view>
  
  <!-- 结束导航按钮 -->
  <view class="end-nav-button" bindtap="endNavigation">
    结束导航
  </view>
  
  <!-- 紧急拨号按钮 -->
  <view class="emergency-button" bindtap="emergencyCall">
    <text>紧急呼叫</text>
  </view>
  
  <!-- AI助手唤醒提示 -->
  <view class="ai-hint">
    说"小颐小颐"唤醒AI助手
  </view>
</view>