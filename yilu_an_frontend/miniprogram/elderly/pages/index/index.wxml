<!--elder/pages/index/index.wxml-->
<view class="container">
  <!-- 顶部信息区 -->
  <view class="header">
    <logo />
  </view>

  <!-- 核心功能区域 -->
  <view class="function-area">
    <!-- 导航出门按钮 -->
    <navigator url="/elder/pages/navigate/navigate" class="function-button orange">
      <view class="button-content">
        <image class="button-icon" src="/assets/svg/navigation-icon.svg" mode="aspectFit" />
        <view class="button-text">导航出门</view>
      </view>
      
    </navigator>

    <!-- 个人中心按钮 -->
    <navigator url="/elder/pages/profile/profile" class="function-button green">
      <view class="button-content">
        <image class="button-icon" src="/assets/svg/user-icon.svg" mode="aspectFit" />
        <view class="button-text">个人中心</view>
      </view>
      
    </navigator>

    <!-- 联系家属按钮 -->
    <navigator url="/elder/pages/contact/contact" class="function-button blue">
      <view class="button-content">
        <image class="button-icon" src="/assets/svg/phone-icon.svg" mode="aspectFit" />
        <view class="button-text">联系家属</view>
      </view>
      
    </navigator>
  </view>

  <!-- 底部导航栏 -->
  <elder-bottom-nav activeItem="home" />
</view>