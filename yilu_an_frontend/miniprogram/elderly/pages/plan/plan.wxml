<!--elderly/pages/plan/plan.wxml-->
<view class="container">
  <view class="header">
    <view class="back-button" bindtap="goBack">
      <text>←</text>
    </view>
  </view>

  <view class="content">
    <view class="success-icon">
      <!-- <image src="/assets/svg/check-icon.svg" mode="aspectFit" /> -->
       ✅
    </view>

    <text class="title">路线规划好啦</text>

    <view class="route-card">
      <view class="route-item">
        <image class="item-icon" src="/assets/svg/location-icon.svg" mode="aspectFit" />
        <text class="item-label">目的地:</text>
        <text class="item-value">{{routeInfo.destination}}</text>
      </view>
      <view class="route-item">
        <image class="item-icon" src="/assets/svg/distance-icon.svg" mode="aspectFit" />
        <text class="item-label">全程:</text>
        <text class="item-value">{{routeInfo.distance}}米</text>
      </view>
      <view class="route-item">
        <image class="item-icon" src="/assets/svg/route-icon.svg" mode="aspectFit" />
        <text class="item-label">交通:</text>
        <text class="item-value">{{routeInfo.transport}}</text>
      </view>
      <view class="route-item">
        <image class="item-icon" src="/assets/svg/time-icon.svg" mode="aspectFit" />
        <text class="item-label">预计:</text>
        <text class="item-value">{{routeInfo.estimate}}</text>
      </view>
    </view>

    <view class="weather-card" wx:if="{{weather.weather_text || weather.temperature || weather.travel_suggestion}}">
      <text class="weather-title">🌤️ 天气信息</text>
      <view class="weather-content">
        <view class="weather-row" wx:if="{{weather.weather_text}}">
          <text class="weather-label">天气：</text>
          <text class="weather-value">{{weather.weather_text}}</text>
        </view>
        <view class="weather-row" wx:if="{{weather.temperature}}">
          <text class="weather-label">温度：</text>
          <text class="weather-value">{{weather.temperature}}</text>
        </view>
        <view class="weather-row" wx:if="{{weather.wind}}">
          <text class="weather-label">风力：</text>
          <text class="weather-value">{{weather.wind}}</text>
        </view>
        <view class="weather-row" wx:if="{{weather.humidity}}">
          <text class="weather-label">湿度：</text>
          <text class="weather-value">{{weather.humidity}}</text>
        </view>
        <view class="weather-row" wx:if="{{weather.air_quality}}">
          <text class="weather-label">空气质量：</text>
          <text class="weather-value">{{weather.air_quality}}</text>
        </view>
      </view>
    </view>

    <view class="advice-card" wx:if="{{navigationAdvice.clothing_advice || navigationAdvice.items_to_bring.length || navigationAdvice.safety_reminders.length || navigationAdvice.best_time || navigationAdvice.tips.length}}">
      <text class="advice-main-title">📋 出行建议</text>
      
      <view class="advice-section" wx:if="{{navigationAdvice.clothing_advice}}">
        <text class="advice-section-title">🧥 穿衣建议</text>
        <text class="advice-section-content">{{navigationAdvice.clothing_advice}}</text>
      </view>

      <view class="advice-section" wx:if="{{navigationAdvice.items_to_bring.length}}">
        <text class="advice-section-title">🎒 随身物品</text>
        <view class="advice-list">
          <view class="advice-list-item" wx:for="{{navigationAdvice.items_to_bring}}" wx:key="index">
            <text class="list-bullet">•</text>
            <text class="list-content">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="advice-section" wx:if="{{navigationAdvice.safety_reminders.length}}">
        <text class="advice-section-title">🛡️ 安全提醒</text>
        <view class="advice-list">
          <view class="advice-list-item" wx:for="{{navigationAdvice.safety_reminders}}" wx:key="index">
            <text class="list-bullet">•</text>
            <text class="list-content">{{item}}</text>
          </view>
        </view>
      </view>

      <view class="advice-section" wx:if="{{navigationAdvice.best_time}}">
        <text class="advice-section-title">⏰ 最佳出行时段</text>
        <text class="advice-section-content">{{navigationAdvice.best_time}}</text>
      </view>

      <view class="advice-section" wx:if="{{navigationAdvice.tips.length}}">
        <text class="advice-section-title">💡 贴心小贴士</text>
        <view class="advice-list">
          <view class="advice-list-item" wx:for="{{navigationAdvice.tips}}" wx:key="index">
            <text class="list-bullet">•</text>
            <text class="list-content">{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="action-buttons">
      <view class="action-btn primary" bindtap="startNavigate">
        <image class="btn-icon" src="/assets/svg/play-icon.svg" mode="aspectFit" />
        <text class="btn-text">开始导航</text>
      </view>
      <view class="action-btn secondary" bindtap="replan">
        <image class="btn-icon" src="/assets/svg/refresh-icon.svg" mode="aspectFit" />
        <text class="btn-text">重新规划</text>
      </view>
    </view>
  </view>
</view>